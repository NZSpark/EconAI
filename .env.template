# =============================================================================
# EconAI Environment Configuration Template
# Copy this file to .env and fill in the values for your deployment
# =============================================================================

# ---------------------------------------------------------------------------
# General
# ---------------------------------------------------------------------------
COMPOSE_PROJECT_NAME=econai
ENVIRONMENT=development
DEBUG=false
LOG_LEVEL=INFO

# ---------------------------------------------------------------------------
# PostgreSQL
# ---------------------------------------------------------------------------
POSTGRES_VERSION=16
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=econai
POSTGRES_USER=econai
POSTGRES_PASSWORD=econai_secret_change_me
POSTGRES_DATA_DIR=./postgres-data

# ---------------------------------------------------------------------------
# Redis
# ---------------------------------------------------------------------------
REDIS_VERSION=7
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=econai_redis_change_me
REDIS_MAXMEMORY=2gb
REDIS_MAXMEMORY_POLICY=allkeys-lru

# ---------------------------------------------------------------------------
# Milvus Vector Database
# ---------------------------------------------------------------------------
MILVUS_HOST=milvus
MILVUS_PORT=19530
MILVUS_COLLECTION_NAME=econai_chunks
EMBEDDING_DIM=1024
MILVUS_INDEX_TYPE=IVF_FLAT
MILVUS_NLIST=1024

# ---------------------------------------------------------------------------
# MinIO Object Storage
# ---------------------------------------------------------------------------
MINIO_HOST=minio
MINIO_PORT=9000
MINIO_CONSOLE_PORT=9001
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin_change_me
MINIO_ACCESS_KEY=econai_access_key
MINIO_SECRET_KEY=econai_secret_key_change_me
MINIO_DOCUMENT_BUCKET=econai-documents
MINIO_OUTPUT_BUCKET=econai-outputs

# ---------------------------------------------------------------------------
# Nginx
# ---------------------------------------------------------------------------
NGINX_HOST=localhost
NGINX_PORT=80
NGINX_SSL_PORT=443
NGINX_MAX_UPLOAD_SIZE_MB=100

# ---------------------------------------------------------------------------
# JWT Authentication
# ---------------------------------------------------------------------------
JWT_SECRET=econai_jwt_secret_change_me_min_32_chars
JWT_ALGORITHM=HS256
JWT_ACCESS_EXPIRE_MINUTES=120
JWT_REFRESH_EXPIRE_HOURS=24

# ---------------------------------------------------------------------------
# API Gateway
# ---------------------------------------------------------------------------
API_GATEWAY_HOST=0.0.0.0
API_GATEWAY_PORT=8000
CORS_ORIGINS=["*"]
AUDIT_LOG_ENABLED=true
RATE_LIMIT_PER_USER=100
RATE_LIMIT_PER_IP=300
RATE_LIMIT_UPLOAD=20
RATE_LIMIT_TASK_CREATE=10
MAX_REQUEST_SIZE_MB=100

# ---------------------------------------------------------------------------
# Document Service
# ---------------------------------------------------------------------------
DOCUMENT_SERVICE_HOST=0.0.0.0
DOCUMENT_SERVICE_PORT=8001
MINIO_ENDPOINT=minio:9000
MINIO_BUCKET=econai-documents
CHUNK_PARAGRAPH_TARGET_TOKENS=300
CHUNK_PARAGRAPH_MIN_TOKENS=100
CHUNK_PARAGRAPH_MAX_TOKENS=500
CHUNK_SECTION_TARGET_TOKENS=2000
CHUNK_SECTION_MIN_TOKENS=500
CHUNK_SECTION_MAX_TOKENS=3000
CHUNK_PARAGRAPH_OVERLAP=50
CHUNK_SECTION_OVERLAP=100
OCR_LANGUAGE=chi_sim+eng
MAX_FILE_SIZE_MB=100
CELERY_DOCUMENT_QUEUE=document

# ---------------------------------------------------------------------------
# KB Service
# ---------------------------------------------------------------------------
KB_SERVICE_HOST=0.0.0.0
KB_SERVICE_PORT=8002
VECTOR_DB_TYPE=milvus
VECTOR_DB_HOST=milvus
VECTOR_DB_PORT=19530
EMBEDDING_MODEL=text2vec-large-chinese
HYBRID_VECTOR_TOP_K=50
HYBRID_BM25_TOP_K=50
HYBRID_RRF_K=60
HYBRID_MERGED_TOP_K=30
RERANKER_MODEL=bge-reranker-large
SEARCH_DEFAULT_TOP_K=10
SEARCH_TIMEOUT_MS=5000

# ---------------------------------------------------------------------------
# Orchestration Service
# ---------------------------------------------------------------------------
ORCHESTRATION_SERVICE_HOST=0.0.0.0
ORCHESTRATION_SERVICE_PORT=8003
AGENT_MAX_ITERATIONS=5
AGENT_TOOL_TIMEOUT_S=60
AGENT_MAX_RETRIEVED_CHUNKS=30
TASK_TIMEOUT_MINUTES=30
CELERY_ORCHESTRATION_QUEUE=orchestration
PROMPT_TEMPLATES_DIR=templates/prompts

# ---------------------------------------------------------------------------
# LLM Router
# ---------------------------------------------------------------------------
LLM_ROUTER_HOST=0.0.0.0
LLM_ROUTER_PORT=8004
ANTHROPIC_API_KEY=
LOCAL_LLM_ENDPOINT=http://host.docker.internal:11434/v1
LOCAL_LLM_DEFAULT_MODEL=qwen2.5-coder:7b
CLOUD_LLM_DEFAULT_MODEL=claude-sonnet-4-6
LLM_DEFAULT_TEMPERATURE=0.3
LLM_DEFAULT_MAX_TOKENS=4096
LLM_REQUEST_TIMEOUT_S=120
LLM_RETRY_MAX=3
LLM_RETRY_BACKOFF_BASE_S=2

# ---------------------------------------------------------------------------
# Citation Service
# ---------------------------------------------------------------------------
CITATION_SERVICE_HOST=0.0.0.0
CITATION_SERVICE_PORT=8005
CITATION_SIMILARITY_THRESHOLD=0.85
CITATION_VERIFY_BATCH_SIZE=50
CITATION_FORMAT_FOOTNOTE=true

# ---------------------------------------------------------------------------
# Output Service
# ---------------------------------------------------------------------------
OUTPUT_SERVICE_HOST=0.0.0.0
OUTPUT_SERVICE_PORT=8006
OUTPUT_STORAGE_PATH=outputs/
OUTPUT_TEMPLATES_DIR=templates/output/
DOCX_INSTITUTION_NAME=EconAI Institution
DOCX_DEFAULT_FONT=仿宋_GB2312
PPTX_DEFAULT_THEME=default
OUTPUT_MAX_FILE_SIZE_MB=50

# ---------------------------------------------------------------------------
# User Service
# ---------------------------------------------------------------------------
USER_SERVICE_HOST=0.0.0.0
USER_SERVICE_PORT=8007
LDAP_ENABLED=false
LDAP_SERVER=ldap://localhost:389
LDAP_BASE_DN=dc=institution,dc=cn
LDAP_USER_FILTER=(uid=%(username)s)
LDAP_GROUP_MAPPING={}
AUDIT_LOG_RETENTION_MONTHS=6
TOKEN_BLACKLIST_ENABLED=true

# ---------------------------------------------------------------------------
# Celery
# ---------------------------------------------------------------------------
CELERY_BROKER_URL=redis://:econai_redis_change_me@redis:6379/0
CELERY_RESULT_BACKEND=redis://:econai_redis_change_me@redis:6379/1
CELERY_WORKER_CONCURRENCY=4
CELERY_WORKER_MAX_MEMORY_PER_CHILD=512000
CELERY_TASK_TIME_LIMIT=1800
CELERY_TASK_SOFT_TIME_LIMIT=1500

# ---------------------------------------------------------------------------
# Prometheus
# ---------------------------------------------------------------------------
PROMETHEUS_PORT=9090
PROMETHEUS_SCRAPE_INTERVAL=15s

# ---------------------------------------------------------------------------
# Grafana
# ---------------------------------------------------------------------------
GRAFANA_PORT=3000
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin_change_me

# ---------------------------------------------------------------------------
# Default Admin User (for seed data)
# ---------------------------------------------------------------------------
DEFAULT_ADMIN_USERNAME=admin
DEFAULT_ADMIN_PASSWORD=Admin@123456
DEFAULT_ADMIN_EMAIL=admin@econai.local
DEFAULT_GROUP_NAME=Default Group